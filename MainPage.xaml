                <Label Text="No tracking, no ads, no hassle" FontSize="15" Margin="0,20,0,0" HorizontalOptions="Center"/>
                <Label Text="A lightweight, battery saving app designed for you" FontSize="15" Margin="0,5,0,0" HorizontalOptions="Center"/>
                <HorizontalStackLayout Margin="0,50,0,0" HorizontalOptions="Center">
                    <VerticalStackLayout HorizontalOptions="Start">
                        <Label Text="Use more rows" FontSize="22"/>
                        <Label Text="May result in app not fitting your display (still usable but you will have to scroll down)." FontSize="12"/>
                    </VerticalStackLayout>
                    <Switch HorizontalOptions="End" x:Name="optionToggle"/>
                </HorizontalStackLayout>
                <Button Margin="20" Text="Confirm" Clicked="confirmClicked"/>
            </VerticalStackLayout>

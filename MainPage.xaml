                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Text="Score Keeper" FontSize="25" Grid.Column="0" VerticalOptions="Center" HorizontalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="titleTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                    <Button Text="Settings" Grid.Column="1" VerticalOptions="Center" x:Name="Settings" HorizontalOptions="End" Clicked="Settings_Clicked"/>
                </Grid>
                <Grid Grid.Row="0" Grid.Column="0" IsVisible="False" x:Name="extendedTitle">
